<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════ PERMISSIONS ═══════════════════ -->

    <!-- Network (for server calls in Phase 2) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Media / Storage — Android 13+ uses granular permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Fallback for Android 9–12 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Writing downloads to public Music folder -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Foreground service for background audio playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Wake lock so ExoPlayer doesn't pause when screen turns off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Post notifications (for media notification on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".GrooveApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GrooveMusicPlayer"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- ═══════════════════ MAIN ACTIVITY ═══════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.GrooveMusicPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══════════════════ PLAYBACK SERVICE ═══════════════════ -->
        <service
            android:name=".player.GroovePlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- ═══════════════════ WORKMANAGER ═══════════════════ -->
        <!--
             CRITICAL: Remove the default WorkManager auto-initializer so that
             GrooveApp.workManagerConfiguration (with HiltWorkerFactory) is used instead.
             Without this, WorkManager ignores HiltWorkerFactory and the DownloadWorker
             crashes with an injection error immediately on creation (silent failure).
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
